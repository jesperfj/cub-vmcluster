#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# cub-vmcluster infrastructure operations
# =============================================================================
# Manages AWS resources in the demo account for cub-vmcluster.
# All commands are idempotent.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- Source environment config ---
if [[ -f "$SCRIPT_DIR/env.sh" ]]; then
    source "$SCRIPT_DIR/env.sh"
else
    echo "Error: No env.sh found in $SCRIPT_DIR" >&2
    exit 1
fi

# --- Derived config ---
export AWS_PROFILE="confighub-${ENV_NAME}"
export AWS_DEFAULT_REGION="$AWS_REGION"
unset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN 2>/dev/null || true

PREFIX="vmcluster"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}▸${NC} $*"; }
log_success() { echo -e "${GREEN}✓${NC} $*"; }
log_warn()    { echo -e "${YELLOW}⚠${NC} $*"; }
log_error()   { echo -e "${RED}✗${NC} $*" >&2; }
die()         { log_error "$@"; exit 1; }

verify_account() {
    local actual
    actual=$(aws sts get-caller-identity --query Account --output text 2>/dev/null) || {
        die "Not authenticated. Run: ./ops aws-login"
    }
    if [[ "$actual" != "$AWS_ACCOUNT_ID" ]]; then
        die "Wrong account! Expected $AWS_ACCOUNT_ID, got $actual"
    fi
}

require_aws_profile() {
    if ! grep -q "\\[profile $AWS_PROFILE\\]" ~/.aws/config 2>/dev/null; then
        die "AWS profile '$AWS_PROFILE' not found in ~/.aws/config

Add it:

  [profile $AWS_PROFILE]
  sso_session = confighub
  sso_account_id = $AWS_ACCOUNT_ID
  sso_role_name = $ROLE_NAME

Then run: ./ops aws-login"
    fi
}

confirm() {
    local prompt="$1"
    echo -en "${YELLOW}$prompt [y/N]:${NC} "
    read -r response
    [[ "$response" =~ ^[Yy]$ ]]
}

# --- Commands ---

cmd_aws_login() {
    require_aws_profile
    aws sso login --profile "$AWS_PROFILE"
    verify_account
    log_success "Authenticated to $ENV_NAME ($AWS_ACCOUNT_ID)"
}

cmd_setup() {
    verify_account

    # --- VPC ---
    local vpc_id
    vpc_id=$(aws ec2 describe-vpcs \
        --filters "Name=tag:Name,Values=${PREFIX}-vpc" \
        --query "Vpcs[0].VpcId" --output text)
    if [[ "$vpc_id" == "None" ]]; then
        log_info "Creating VPC..."
        vpc_id=$(aws ec2 create-vpc \
            --cidr-block 10.99.0.0/16 \
            --tag-specifications "ResourceType=vpc,Tags=[{Key=Name,Value=${PREFIX}-vpc}]" \
            --query "Vpc.VpcId" --output text)
        aws ec2 modify-vpc-attribute --vpc-id "$vpc_id" --enable-dns-hostnames
        aws ec2 modify-vpc-attribute --vpc-id "$vpc_id" --enable-dns-support
        log_success "VPC: $vpc_id"
    else
        log_success "VPC exists: $vpc_id"
    fi

    # --- Internet Gateway ---
    local igw_id
    igw_id=$(aws ec2 describe-internet-gateways \
        --filters "Name=tag:Name,Values=${PREFIX}-igw" \
        --query "InternetGateways[0].InternetGatewayId" --output text)
    if [[ "$igw_id" == "None" ]]; then
        log_info "Creating internet gateway..."
        igw_id=$(aws ec2 create-internet-gateway \
            --tag-specifications "ResourceType=internet-gateway,Tags=[{Key=Name,Value=${PREFIX}-igw}]" \
            --query "InternetGateway.InternetGatewayId" --output text)
        aws ec2 attach-internet-gateway --internet-gateway-id "$igw_id" --vpc-id "$vpc_id"
        log_success "IGW: $igw_id"
    else
        log_success "IGW exists: $igw_id"
    fi

    # --- Public Subnet ---
    local subnet_id
    subnet_id=$(aws ec2 describe-subnets \
        --filters "Name=tag:Name,Values=${PREFIX}-public" "Name=vpc-id,Values=$vpc_id" \
        --query "Subnets[0].SubnetId" --output text)
    if [[ "$subnet_id" == "None" ]]; then
        log_info "Creating public subnet..."
        subnet_id=$(aws ec2 create-subnet \
            --vpc-id "$vpc_id" \
            --cidr-block 10.99.1.0/24 \
            --availability-zone "${AWS_REGION}a" \
            --tag-specifications "ResourceType=subnet,Tags=[{Key=Name,Value=${PREFIX}-public}]" \
            --query "Subnet.SubnetId" --output text)
        aws ec2 modify-subnet-attribute --subnet-id "$subnet_id" --map-public-ip-on-launch
        log_success "Subnet: $subnet_id"
    else
        log_success "Subnet exists: $subnet_id"
    fi

    # --- Route Table ---
    local rt_id
    rt_id=$(aws ec2 describe-route-tables \
        --filters "Name=tag:Name,Values=${PREFIX}-public-rt" "Name=vpc-id,Values=$vpc_id" \
        --query "RouteTables[0].RouteTableId" --output text)
    if [[ "$rt_id" == "None" ]]; then
        log_info "Creating route table..."
        rt_id=$(aws ec2 create-route-table \
            --vpc-id "$vpc_id" \
            --tag-specifications "ResourceType=route-table,Tags=[{Key=Name,Value=${PREFIX}-public-rt}]" \
            --query "RouteTable.RouteTableId" --output text)
        aws ec2 create-route --route-table-id "$rt_id" --destination-cidr-block 0.0.0.0/0 --gateway-id "$igw_id" > /dev/null
        aws ec2 associate-route-table --route-table-id "$rt_id" --subnet-id "$subnet_id" > /dev/null
        log_success "Route table: $rt_id"
    else
        log_success "Route table exists: $rt_id"
    fi

    # --- IAM: Instance role ---
    # This role is used by all vmcluster EC2 instances. It needs:
    # - SSM for shell access
    # - EC2 + Route53 so the in-cluster vmcluster worker can provision more instances
    # - IAM PassRole so it can assign this same profile to new instances
    local instance_role="${PREFIX}-instance"
    if aws iam get-role --role-name "$instance_role" &>/dev/null; then
        log_success "Instance role exists: $instance_role"
    else
        log_info "Creating instance role: $instance_role"
        aws iam create-role \
            --role-name "$instance_role" \
            --assume-role-policy-document '{"Version":"2012-10-17","Statement":[{"Effect":"Allow","Principal":{"Service":"ec2.amazonaws.com"},"Action":"sts:AssumeRole"}]}' \
            --description "EC2 instance role for VMCluster nodes (SSM + provisioning)" > /dev/null
        log_success "Instance role: $instance_role"
    fi

    aws iam attach-role-policy \
        --role-name "$instance_role" \
        --policy-arn "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore" 2>/dev/null || true

    aws iam put-role-policy \
        --role-name "$instance_role" \
        --policy-name "${PREFIX}-instance-policy" \
        --policy-document "$(cat <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EC2",
      "Effect": "Allow",
      "Action": "ec2:*",
      "Resource": "*",
      "Condition": {"StringEquals": {"aws:RequestedRegion": ["$AWS_REGION"]}}
    },
    {
      "Sid": "Route53",
      "Effect": "Allow",
      "Action": ["route53:ChangeResourceRecordSets", "route53:GetHostedZone", "route53:ListResourceRecordSets"],
      "Resource": "arn:aws:route53:::hostedzone/*"
    },
    {
      "Sid": "IAMPassRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/${PREFIX}-instance"
    },
    {
      "Sid": "Tagging",
      "Effect": "Allow",
      "Action": "ec2:CreateTags",
      "Resource": "arn:aws:ec2:*:*:instance/*"
    },
    {
      "Sid": "SSMCommands",
      "Effect": "Allow",
      "Action": ["ssm:SendCommand", "ssm:GetCommandInvocation"],
      "Resource": "*"
    }
  ]
}
EOF
        )"

    local instance_profile="${PREFIX}-instance"
    if aws iam get-instance-profile --instance-profile-name "$instance_profile" &>/dev/null; then
        log_success "Instance profile exists: $instance_profile"
    else
        log_info "Creating instance profile: $instance_profile"
        aws iam create-instance-profile --instance-profile-name "$instance_profile" > /dev/null
        aws iam add-role-to-instance-profile \
            --instance-profile-name "$instance_profile" \
            --role-name "$instance_role"
        log_info "Waiting 10s for instance profile propagation..."
        sleep 10
        log_success "Instance profile: $instance_profile"
    fi

    # --- Route53 ---
    local zone_id=""
    if [[ -n "$DOMAIN" ]]; then
        zone_id=$(aws route53 list-hosted-zones-by-name \
            --dns-name "$DOMAIN" \
            --query "HostedZones[?Name=='${DOMAIN}.'].Id" --output text | head -1 | sed 's|/hostedzone/||')
        if [[ -z "$zone_id" ]]; then
            log_info "Creating Route53 hosted zone: $DOMAIN"
            zone_id=$(aws route53 create-hosted-zone \
                --name "$DOMAIN" \
                --caller-reference "vmcluster-$(date +%s)" \
                --query "HostedZone.Id" --output text | sed 's|/hostedzone/||')
            log_success "Zone: $zone_id"
            log_warn "Delegate this zone from your registrar! NS records:"
            aws route53 get-hosted-zone --id "$zone_id" \
                --query "DelegationSet.NameServers" --output text | tr '\t' '\n' | sed 's/^/    /'
        else
            log_success "Route53 zone exists: $zone_id ($DOMAIN)"
        fi
    else
        log_info "Skipping Route53 (DOMAIN not set in env.sh)"
    fi

    # --- Summary ---
    echo ""
    log_success "Infrastructure ready"
    echo ""
    echo "  Run cub-vmcluster locally with:"
    echo ""
    echo "  CONFIGHUB_URL=https://hub.confighub.com \\"
    echo "  CONFIGHUB_WORKER_ID=<worker-id> \\"
    echo "  CONFIGHUB_WORKER_SECRET=<worker-secret> \\"
    echo "  AWS_PROFILE=confighub-demo \\"
    echo "  SUBNET_ID=$subnet_id \\"
    echo "  INSTANCE_PROFILE_NAME=$instance_profile \\"
    [[ -n "$zone_id" ]] && echo "  ROUTE53_HOSTED_ZONE_ID=$zone_id \\"
    echo "  ./cub-vmcluster"
    echo ""
    echo "  To self-host, set installVMClusterWorker: true in the VMCluster spec."
    echo ""
}

cmd_teardown() {
    local force="${1:-}"
    verify_account

    # Check for running instances
    local instance_ids
    instance_ids=$(aws ec2 describe-instances \
        --filters "Name=tag:confighub:managed-by,Values=cub-vmcluster" \
                  "Name=instance-state-name,Values=running,pending,stopping,stopped" \
        --query "Reservations[].Instances[].InstanceId" --output text)
    if [[ -n "$instance_ids" ]]; then
        if [[ "$force" == "--force" ]]; then
            log_info "Terminating instances: $instance_ids"
            aws ec2 terminate-instances --instance-ids $instance_ids > /dev/null
            log_info "Waiting for instances to terminate..."
            aws ec2 wait instance-terminated --instance-ids $instance_ids
            log_success "All instances terminated"
        else
            log_warn "Instances still running: $instance_ids"
            log_info "Use './ops teardown --force' to terminate all instances and tear down everything"
            confirm "Continue teardown without terminating instances?" || exit 1
        fi
    fi

    # Route53 zone is NOT deleted — it's a persistent resource with registrar delegation.
    # A records created by the bridge will be orphaned but harmless.

    # Instance profile
    local instance_profile="${PREFIX}-instance"
    local instance_role="${PREFIX}-instance"
    if aws iam get-instance-profile --instance-profile-name "$instance_profile" &>/dev/null; then
        aws iam remove-role-from-instance-profile \
            --instance-profile-name "$instance_profile" --role-name "$instance_role" 2>/dev/null || true
        aws iam delete-instance-profile --instance-profile-name "$instance_profile"
        log_success "Deleted instance profile"
    fi

    # Instance role
    if aws iam get-role --role-name "$instance_role" &>/dev/null; then
        # Detach all managed policies
        local managed_policies
        managed_policies=$(aws iam list-attached-role-policies --role-name "$instance_role" \
            --query "AttachedPolicies[].PolicyArn" --output text)
        for policy_arn in $managed_policies; do
            aws iam detach-role-policy --role-name "$instance_role" --policy-arn "$policy_arn" 2>/dev/null || true
        done
        # Delete all inline policies
        local inline_policies
        inline_policies=$(aws iam list-role-policies --role-name "$instance_role" \
            --query "PolicyNames[]" --output text)
        for policy_name in $inline_policies; do
            aws iam delete-role-policy --role-name "$instance_role" --policy-name "$policy_name" 2>/dev/null || true
        done
        aws iam delete-role --role-name "$instance_role"
        log_success "Deleted instance role"
    fi

    # Legacy provisioner role (from earlier cross-account setup)
    local provisioner_role="${PREFIX}-provisioner"
    if aws iam get-role --role-name "$provisioner_role" &>/dev/null; then
        local prov_inline
        prov_inline=$(aws iam list-role-policies --role-name "$provisioner_role" \
            --query "PolicyNames[]" --output text)
        for pn in $prov_inline; do
            aws iam delete-role-policy --role-name "$provisioner_role" --policy-name "$pn" 2>/dev/null || true
        done
        aws iam delete-role --role-name "$provisioner_role"
        log_success "Deleted legacy provisioner role"
    fi

    # Security groups (created by the bridge)
    local sg_ids
    sg_ids=$(aws ec2 describe-security-groups \
        --filters "Name=tag:confighub:managed-by,Values=cub-vmcluster" \
        --query "SecurityGroups[].GroupId" --output text)
    for sg_id in $sg_ids; do
        aws ec2 delete-security-group --group-id "$sg_id" 2>/dev/null && \
            log_success "Deleted security group: $sg_id" || \
            log_warn "Could not delete security group $sg_id (may have dependencies)"
    done

    # Route table
    local rt_id
    rt_id=$(aws ec2 describe-route-tables \
        --filters "Name=tag:Name,Values=${PREFIX}-public-rt" \
        --query "RouteTables[0].RouteTableId" --output text)
    if [[ "$rt_id" != "None" ]]; then
        local assoc_ids
        assoc_ids=$(aws ec2 describe-route-tables --route-table-ids "$rt_id" \
            --query "RouteTables[0].Associations[?!Main].RouteTableAssociationId" --output text)
        for assoc_id in $assoc_ids; do
            aws ec2 disassociate-route-table --association-id "$assoc_id" 2>/dev/null || true
        done
        aws ec2 delete-route-table --route-table-id "$rt_id"
        log_success "Deleted route table"
    fi

    # Subnet
    local subnet_id
    subnet_id=$(aws ec2 describe-subnets \
        --filters "Name=tag:Name,Values=${PREFIX}-public" \
        --query "Subnets[0].SubnetId" --output text)
    if [[ "$subnet_id" != "None" ]]; then
        aws ec2 delete-subnet --subnet-id "$subnet_id"
        log_success "Deleted subnet"
    fi

    # Internet gateway
    local igw_id
    igw_id=$(aws ec2 describe-internet-gateways \
        --filters "Name=tag:Name,Values=${PREFIX}-igw" \
        --query "InternetGateways[0].InternetGatewayId" --output text)
    if [[ "$igw_id" != "None" ]]; then
        local vpc_id
        vpc_id=$(aws ec2 describe-internet-gateways --internet-gateway-ids "$igw_id" \
            --query "InternetGateways[0].Attachments[0].VpcId" --output text)
        [[ "$vpc_id" != "None" ]] && aws ec2 detach-internet-gateway --internet-gateway-id "$igw_id" --vpc-id "$vpc_id"
        aws ec2 delete-internet-gateway --internet-gateway-id "$igw_id"
        log_success "Deleted internet gateway"
    fi

    # VPC
    local vpc_id
    vpc_id=$(aws ec2 describe-vpcs \
        --filters "Name=tag:Name,Values=${PREFIX}-vpc" \
        --query "Vpcs[0].VpcId" --output text)
    if [[ "$vpc_id" != "None" ]]; then
        aws ec2 delete-vpc --vpc-id "$vpc_id"
        log_success "Deleted VPC"
    fi

    log_success "Teardown complete"
}

cmd_status() {
    verify_account

    echo ""
    log_info "VPC"
    aws ec2 describe-vpcs \
        --filters "Name=tag:Name,Values=${PREFIX}-vpc" \
        --query "Vpcs[].[VpcId,State,CidrBlock]" --output table

    log_info "Subnet"
    aws ec2 describe-subnets \
        --filters "Name=tag:Name,Values=${PREFIX}-public" \
        --query "Subnets[].[SubnetId,AvailabilityZone,CidrBlock,MapPublicIpOnLaunch]" --output table

    log_info "Instances"
    aws ec2 describe-instances \
        --filters "Name=tag:confighub:managed-by,Values=cub-vmcluster" \
        --query "Reservations[].Instances[].[InstanceId,State.Name,PublicIpAddress,Tags[?Key=='Name']|[0].Value,Tags[?Key=='confighub:status']|[0].Value]" \
        --output table

    log_info "IAM Roles"
    for role in "${PREFIX}-provisioner" "${PREFIX}-instance"; do
        if aws iam get-role --role-name "$role" &>/dev/null; then
            echo "    $role ✓"
        else
            echo "    $role ✗"
        fi
    done

    if [[ -n "$DOMAIN" ]]; then
        log_info "Route53"
        local zone_id
        zone_id=$(aws route53 list-hosted-zones-by-name \
            --dns-name "$DOMAIN" \
            --query "HostedZones[?Name=='${DOMAIN}.'].Id" --output text | head -1 | sed 's|/hostedzone/||')
        if [[ -n "$zone_id" ]]; then
            echo "    Zone: $zone_id ($DOMAIN)"
            aws route53 list-resource-record-sets --hosted-zone-id "$zone_id" \
                --query "ResourceRecordSets[?Type == 'A'].[Name,ResourceRecords[0].Value]" --output table
        else
            echo "    No zone found for $DOMAIN"
        fi
    fi
    echo ""
}

# --- Main ---

usage() {
    echo "Usage: ./ops <command>"
    echo ""
    echo "Commands:"
    echo "  aws-login   Authenticate via AWS SSO"
    echo "  setup       Create all AWS infrastructure (idempotent)"
    echo "  teardown [--force]  Remove all AWS infrastructure (--force terminates instances)"
    echo "  status      Show current infrastructure state"
}

case "${1:-}" in
    aws-login) cmd_aws_login ;;
    setup)     cmd_setup ;;
    teardown)  cmd_teardown "${2:-}" ;;
    status)    cmd_status ;;
    *)         usage ;;
esac
