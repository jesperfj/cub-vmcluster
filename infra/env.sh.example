# cub-vmcluster Environment Configuration
# Copy to env.sh and fill in your values:
#   cp env.sh.example env.sh

export AWS_ACCOUNT_ID=""          # Your AWS account ID
export AWS_REGION="us-east-2"
export AWS_SSO_START_URL=""       # Your AWS SSO start URL (or remove for non-SSO)
export ROLE_NAME="AdministratorAccess"
export ENV_NAME="demo"

# Route53 domain (optional — leave empty to skip DNS setup)
export DOMAIN=""
