#!/bin/bash
set -euo pipefail

# Cloud-init script for VMCluster: {{.ClusterName}}
# Generated by cub-vmcluster bridge

export DEBIAN_FRONTEND=noninteractive

# --- Install AWS CLI (not present on Ubuntu by default) ---
snap install aws-cli --classic 2>/dev/null || apt-get install -y awscli 2>/dev/null || true

# --- Metadata helpers ---
TOKEN=$(curl -s -X PUT http://169.254.169.254/latest/api/token -H "X-aws-ec2-metadata-token-ttl-seconds: 300")
imds() { curl -sf -H "X-aws-ec2-metadata-token: $TOKEN" "http://169.254.169.254/latest/meta-data/$1"; }
INSTANCE_ID=$(imds instance-id)
REGION=$(imds placement/region)
PUBLIC_IP=$(imds public-ipv4)

tag_status() {
  aws ec2 create-tags --region "$REGION" --resources "$INSTANCE_ID" \
    --tags "Key=confighub:status,Value=$1" 2>/dev/null || true
}

tag_status "downloading-k3s"

# --- Install k3s ---
curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION="{{.K3sVersion}}" \
  INSTALL_K3S_EXEC="server --tls-san $PUBLIC_IP --tls-san {{.IngressDomain}} --write-kubeconfig-mode 644" sh -

tag_status "waiting-for-k3s"

# Wait for k3s to be ready
echo "Waiting for k3s..."
until /usr/local/bin/kubectl get nodes --kubeconfig /etc/rancher/k3s/k3s.yaml &>/dev/null; do
  sleep 2
done
echo "k3s is ready"

tag_status "deploying-worker"

# --- Deploy cub-worker as a k3s manifest ---
# Ensure manifests directory exists (k3s creates it at startup but there's a race)
mkdir -p /var/lib/rancher/k3s/server/manifests/
cat > /var/lib/rancher/k3s/server/manifests/confighub-worker.yaml <<'MANIFEST'
apiVersion: v1
kind: Namespace
metadata:
  name: confighub-system
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: cub-worker
  namespace: confighub-system
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: cub-worker-cluster-admin
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: cluster-admin
subjects:
- kind: ServiceAccount
  name: cub-worker
  namespace: confighub-system
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: cub-worker
  namespace: confighub-system
spec:
  replicas: 1
  selector:
    matchLabels:
      app: cub-worker
  template:
    metadata:
      labels:
        app: cub-worker
    spec:
      serviceAccountName: cub-worker
      containers:
      - name: cub-worker
        image: {{.WorkerImage}}
        env:
        - name: CONFIGHUB_URL
          value: "{{.ConfigHubURL}}"
        - name: CONFIGHUB_WORKER_ID
          value: "{{.WorkerID}}"
        - name: CONFIGHUB_WORKER_SECRET
          value: "{{.WorkerSecret}}"
        - name: CONFIGHUB_WORKER_PROVIDER_TYPES
          value: "{{.ProviderTypes}}"
MANIFEST

{{if .InstallVMClusterWorker}}
# --- Deploy cub-vmcluster worker (self-install for bootstrap pivot) ---
cat > /var/lib/rancher/k3s/server/manifests/cub-vmcluster.yaml <<'VMCMANIFEST'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: cub-vmcluster
  namespace: confighub-system
spec:
  replicas: 1
  selector:
    matchLabels:
      app: cub-vmcluster
  template:
    metadata:
      labels:
        app: cub-vmcluster
    spec:
      serviceAccountName: cub-worker
      containers:
      - name: cub-vmcluster
        image: {{.VMClusterWorkerImage}}
        env:
        - name: CONFIGHUB_URL
          value: "{{.ConfigHubURL}}"
        - name: CONFIGHUB_WORKER_ID
          value: "{{.VMClusterWorkerID}}"
        - name: CONFIGHUB_WORKER_SECRET
          value: "{{.VMClusterWorkerSecret}}"
        - name: SUBNET_ID
          value: "{{.VMClusterSubnetID}}"
        - name: ROUTE53_HOSTED_ZONE_ID
          value: "{{.VMClusterHostedZoneID}}"
        - name: INSTANCE_PROFILE_NAME
          value: "{{.VMClusterInstanceProfile}}"
VMCMANIFEST
{{end}}

{{if .TLSEnabled}}
tag_status "deploying-cert-manager"

# --- Deploy cert-manager ---
/usr/local/bin/kubectl apply --kubeconfig /etc/rancher/k3s/k3s.yaml \
  -f https://github.com/cert-manager/cert-manager/releases/latest/download/cert-manager.yaml

tag_status "waiting-for-cert-manager"

# Wait for cert-manager webhook to be ready
echo "Waiting for cert-manager..."
/usr/local/bin/kubectl wait --kubeconfig /etc/rancher/k3s/k3s.yaml \
  --for=condition=Available deployment/cert-manager-webhook \
  -n cert-manager --timeout=120s

# Create ClusterIssuer for Let's Encrypt
cat > /var/lib/rancher/k3s/server/manifests/cluster-issuer.yaml <<ISSUER
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: letsencrypt-prod
spec:
  acme:
    server: https://acme-v02.api.letsencrypt.org/directory
    email: {{.TLSEmail}}
    privateKeySecretRef:
      name: letsencrypt-prod
    solvers:
    - http01:
        ingress:
          class: traefik
ISSUER
{{end}}

tag_status "ready"
echo "VMCluster {{.ClusterName}} is ready"
